over "Render"
{
    over "OmniverseKit"
    {
        over "HydraTextures"
        {
            over "omni_kit_widget_viewport_ViewportTexture_0"
            {
                rel camera = </World/Cameras/FlyThrough>
                bool omni:rtx:rt:ecoMode:enabled
                bool omni:rtx:scene:useViewLightingMode
                rel orderedVars = </Render/Vars/LdrColor>
                custom bool overrideClipRange = 0
                uniform int2 resolution = (1280, 720)
            }
        }
    }
}

