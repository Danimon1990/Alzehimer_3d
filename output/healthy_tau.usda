#usda 1.0
(
    customLayerData = {
        dictionary cameraSettings = {
            dictionary Front = {
                double3 position = (0, 0, 500)
                double radius = 5
            }
            dictionary Perspective = {
                double3 position = (19.04230088167732, 13.473307155613764, -39.139279757986685)
                double3 target = (16.835318466604, -6.510312952403332, 15.457647267352947)
            }
            dictionary Right = {
                double3 position = (-500, 0, 0)
                double radius = 5
            }
            dictionary Top = {
                double3 position = (15.853560434813664, 500, -8.883883711149457)
                double radius = 61.058294677734374
            }
            string boundCamera = "/World/Cameras/FlyThrough"
        }
        dictionary omni_layer = {
            string authoring_layer = "./healthy_tau.usda"
        }
        dictionary renderSettings = {
        }
    }
    defaultPrim = "World"
    endTimeCode = 240
    metersPerUnit = 0.01
    startTimeCode = 1
    timeCodesPerSecond = 24
    subLayers = [
        @healthy_tau_camera.usda@,
        @healthy_tau_materials.usda@,
        @healthy_tau_alignment.usda@,
        @healthy_tau_base.usda@
    ]
    upAxis = "Y"
)

def Xform "World"
{
