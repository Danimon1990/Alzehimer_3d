        }

        over "Microtubules_06"
        {
            float xformOp:rotateX = 173.54794
            float xformOp:rotateY = 2.129183
            float xformOp:rotateZ = 14.391725
            float3 xformOp:scale = (0.1, 0.1, 0.1)
            double3 xformOp:translate = (0.2208202118093694, -47.52847753031715, 1.1914002413986737)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateZ", "xformOp:rotateY", "xformOp:rotateX", "xformOp:scale"]

            over "Prototypes"
            {
                over "Segment"
                {
                    over "BézierCurve_006"
                    {
                        over "Mesh_006"
                        {
                            quatf xformOp:orient = (1, 0, 0, 0)
                            float3 xformOp:scale = (1, 1, 1)
                            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
                        }
                    }
                }
            }
        }

        over "Microtubules_03"
        {
            float xformOp:rotateX = 179.57585
            float xformOp:rotateY = -0.063509375
            float xformOp:rotateZ = -0.9031304
            float3 xformOp:scale = (0.1, 0.1, 0.1)
            double3 xformOp:translate = (-0.39999999999998626, -26.6, 0.3259572767731044)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateZ", "xformOp:rotateY", "xformOp:rotateX", "xformOp:scale"]
        }

        over "Microtubules_04"
        {
