#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def Scope "Cameras"
    {
        def Camera "FlyThrough"
        {
            float2 clippingRange = (0.1, 10000)
            float focalLength = 35
            float xformOp:rotateX.timeSamples = {
                1: -90,
                240: -90,
            }
            float xformOp:rotateY.timeSamples = {
                1: 0,
                240: 0,
            }
            double3 xformOp:translate.timeSamples = {
                1: (-0.4, -52, 0),
                240: (-0.4, 6, 0),
            }
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateY", "xformOp:rotateX"]
        }
    }
}

over "Render"
{
    over RenderSettings "HealthyTauRenderSettings"
    {
        rel camera = </World/Cameras/FlyThrough>
    }
}

